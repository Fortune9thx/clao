# CLAO — frontend GenLayer config. Copy to .env.local (gitignored).
# `npm run deploy` writes VITE_CLAO_ADDRESS here automatically.

# Deployed CLAORegistry address. Until set, the app runs on the local mock
# gateway (fully interactive, no wallet needed).
VITE_CLAO_ADDRESS=

# Target network: studionet | localnet | testnetBradbury
VITE_GL_NETWORK=studionet
