# Deploy/smoke-script secrets — copy to scripts/.env (gitignored) and fill in.
# These are SERVER-SIDE only; never commit a funded key.

# Target network: studionet | localnet | testnetBradbury
CLAO_NETWORK=studionet

# Funded deployer key. Generate one:
#   node -e "import('genlayer-js').then(m=>console.log(m.generatePrivateKey()))"
# then fund it from the Studionet faucet at https://studio.genlayer.com
CLAO_DEPLOYER_PRIVATE_KEY=

# Optional DAO seed (constructor args). Defaults shown.
CLAO_DAO_ID=dao-01
CLAO_DAO_NAME=Bradbury Alpha DAO
CLAO_DAO_TREASURY=2,450,000 USD

# Set after deploy (deploy.mjs writes this to .env.local automatically).
VITE_CLAO_ADDRESS=
